<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="sn.sadikh.examen_javafx.controller.consultation.consultationController">
    <Pane prefHeight="650.0" prefWidth="280.0" style="-fx-background-color: #2c3e50;">
        <Label layoutX="20.0" layoutY="20.0" text="Gestion Patient" textFill="WHITE">
            <font>
                <Font name="System Bold" size="18.0" />
            </font>
        </Label>

        <Label layoutX="20.0" layoutY="65.0" text="Diagnostic" textFill="WHITE" />
        <TextArea fx:id="txtDianostic" layoutX="20.0" layoutY="85.0" prefHeight="50.0" prefWidth="240.0" wrapText="true" />

        <Label layoutX="20.0" layoutY="149.0" text="Prescription" textFill="WHITE" />
        <TextArea fx:id="txtPrescription" layoutX="19.0" layoutY="174.0" prefHeight="81.0" prefWidth="240.0" wrapText="true" />

        <Label layoutX="17.0" layoutY="277.0" text="Observations" textFill="WHITE" />
        <TextArea fx:id="txtObservation" layoutX="19.0" layoutY="304.0" prefHeight="95.0" prefWidth="240.0" wrapText="true" />

        <Label layoutX="20.0" layoutY="409.0" text="Rendez bous" textFill="WHITE" />
        <ComboBox fx:id="cbRDV" layoutX="19.0" layoutY="445.0" prefWidth="240.0" />

        <VBox layoutX="20.0" layoutY="490.0" spacing="10.0" />
        <HBox layoutX="20.0" layoutY="573.0" spacing="10.0">
            <Button onAction="#modifier" prefHeight="26.0" prefWidth="241.0" style="-fx-background-color: #2980b9;" text="Modifier" textFill="WHITE" />
        </HBox>
        <HBox layoutX="19.0" layoutY="510.0" spacing="10.0">
            <Button onAction="#enregistrer" prefWidth="115.0" style="-fx-background-color: #27ae60;" text="Enregistrer" textFill="WHITE" />
            <Button onAction="#annuler" prefWidth="115.0" style="-fx-background-color: #7f8c8d;" text="Annuler" textFill="WHITE" />
        </HBox>
    </Pane>

    <TableView fx:id="table" layoutX="280.0" prefHeight="650.0" prefWidth="720.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="280.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
        <columns>
            <TableColumn fx:id="colId" prefWidth="40.0" text="ID" />

            <TableColumn fx:id="colMedecin" prefWidth="120.0" text="Médecin" />
            <TableColumn fx:id="colPatient" prefWidth="120.0" text="Patient" />

            <TableColumn fx:id="colDate" prefWidth="100.0" text="Date" />

            <TableColumn fx:id="colDiagnostic" prefWidth="150.0" text="Diagnostic" />
            <TableColumn fx:id="colPrescription" prefWidth="150.0" text="Prescription" />

            <TableColumn fx:id="colObservation" prefWidth="140.0" text="Observations" />
        </columns>
    </TableView>

</AnchorPane>
