<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import javafx.collections.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="sn.sadikh.examen_javafx.controller.patient.PatientController">

    <Pane prefHeight="650.0" prefWidth="280.0" style="-fx-background-color: #2c3e50;">
        <Label layoutX="20.0" layoutY="20.0" text="Gestion Patient" textFill="WHITE">
            <font>
                <Font name="System Bold" size="18.0" />
            </font>
        </Label>

        <Label layoutX="20.0" layoutY="65.0" text="Nom" textFill="WHITE" />
        <TextField fx:id="txtNom" layoutX="20.0" layoutY="85.0" prefWidth="240.0" />

        <Label layoutX="20.0" layoutY="125.0" text="Prénom" textFill="WHITE" />
        <TextField fx:id="txtPrenom" layoutX="20.0" layoutY="145.0" prefWidth="240.0" />

        <Label layoutX="20.0" layoutY="185.0" text="Téléphone" textFill="WHITE" />
        <TextField fx:id="txtTel" layoutX="20.0" layoutY="205.0" prefWidth="240.0" />

        <Label layoutX="20.0" layoutY="245.0" text="Adresse" textFill="WHITE" />
        <TextField fx:id="txtAdresse" layoutX="20.0" layoutY="265.0" prefWidth="240.0" />

        <Label layoutX="20.0" layoutY="305.0" text="Date de Naissance" textFill="WHITE" />
        <DatePicker fx:id="dtNaissance" layoutX="20.0" layoutY="325.0" prefWidth="240.0" />

        <Label layoutX="20.0" layoutY="365.0" text="Groupe Sanguin" textFill="WHITE" />
        <ComboBox fx:id="cbGroupeSanguin" layoutX="20.0" layoutY="385.0" prefWidth="240.0">
            <items>
                <FXCollections fx:factory="observableArrayList">
                    <String fx:value="A+" />
                    <String fx:value="A-" />
                    <String fx:value="B+" />
                    <String fx:value="B-" />
                    <String fx:value="AB+" />
                    <String fx:value="AB-" />
                    <String fx:value="O+" />
                    <String fx:value="O-" />
                </FXCollections>
            </items>
        </ComboBox>

        <Label layoutX="20.0" layoutY="425.0" text="Sexe" textFill="WHITE" />
        <ComboBox fx:id="cbSexe" layoutX="20.0" layoutY="445.0" prefWidth="240.0">
            <items>
                <FXCollections fx:factory="observableArrayList">
                    <String fx:value="HOMME+" />
                    <String fx:value="FEMME-" />
                </FXCollections>
            </items>
        </ComboBox>

        <Label layoutX="20.0" layoutY="485.0" text="Antecefent medicaux" textFill="WHITE" />
        <TextField fx:id="txtAnt" layoutX="20.0" layoutY="505.0" prefWidth="240.0" />

        <VBox layoutX="20.0" layoutY="490.0" spacing="10.0" />
         <HBox layoutX="19.0" layoutY="600.0" spacing="10.0">
             <Button onAction="#modifier" prefWidth="115.0" style="-fx-background-color: #2980b9;" text="Modifier" textFill="WHITE" />
             <Button onAction="#supprimer" prefWidth="115.0" style="-fx-background-color: #c0392b;" text="Supprimer" textFill="WHITE" />
         </HBox>
         <HBox layoutX="19.0" layoutY="559.0" spacing="10.0">
             <Button onAction="#enregistrer" prefWidth="115.0" style="-fx-background-color: #27ae60;" text="Enregistrer" textFill="WHITE" />
             <Button onAction="#annuler" prefWidth="115.0" style="-fx-background-color: #7f8c8d;" text="Annuler" textFill="WHITE" />
         </HBox>
    </Pane>

    <TableView fx:id="tablePatients" layoutX="280.0" prefHeight="650.0" prefWidth="720.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="280.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
        <columns>
            <TableColumn fx:id="colId" prefWidth="40.0" text="ID" />
            <TableColumn fx:id="colNom" prefWidth="100.0" text="Nom" />
            <TableColumn fx:id="colPrenom" prefWidth="110.0" text="Prénom" />
            <TableColumn fx:id="colTel" prefWidth="100.0" text="Téléphone" />
            <TableColumn fx:id="colAdresse" prefWidth="130.0" text="Adresse" />
            <TableColumn fx:id="colNaissance" prefWidth="95.0" text="Naissance" />
            <TableColumn fx:id="colGroupe" prefWidth="75.0" text="Groupe" />
            <TableColumn fx:id="colSexe" prefWidth="60.0" text="Sexe" />
        </columns>
    </TableView>
</AnchorPane>
