<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.scene.effect.*?>

<BorderPane fx:id="mainPane" prefHeight="700.0" prefWidth="1200.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="sn.sadikh.examen_javafx.controller.utilisateur.DashboardController">

    <left>
        <VBox prefWidth="240.0" spacing="10.0"
              style="-fx-background-color: #1a252f; -fx-padding: 20; -fx-border-color: #34495e; -fx-border-width: 0 2 0 0;">
            <children>
                <Label text="CLINIQUE SADIKH" textFill="WHITE">
                    <font>
                        <Font name="System Bold" size="22.0" />
                    </font>
                </Label>
                <Separator opacity="0.2" />

                <Button fx:id="btnPatients" onAction="#afficherPatients" prefWidth="200.0"
                        style="-fx-background-color: transparent; -fx-text-fill: white; -fx-alignment: CENTER_LEFT; -fx-cursor: hand;" text="👥 Gestion Patients" />

                <Button fx:id="btnRendezVous" onAction="#afficherRendezVous" prefWidth="200.0"
                        style="-fx-background-color: transparent; -fx-text-fill: white; -fx-alignment: CENTER_LEFT; -fx-cursor: hand;" text="📅 Rendez-vous" />

                <Button fx:id="btnConsultations" onAction="#afficherConsultations" prefWidth="200.0"
                        style="-fx-background-color: transparent; -fx-text-fill: white; -fx-alignment: CENTER_LEFT; -fx-cursor: hand;" text="🩺 Consultations" />

                <Button fx:id="btnFactures" onAction="#afficherFactures" prefWidth="200.0"
                        style="-fx-background-color: transparent; -fx-text-fill: white; -fx-alignment: CENTER_LEFT; -fx-cursor: hand;" text="💰 Facturation" />

                <Separator opacity="0.2" />

                <Button fx:id="btnUtilisateurs" onAction="#afficherUtilisateurs" prefWidth="200.0"
                        style="-fx-background-color: transparent; -fx-text-fill: white; -fx-alignment: CENTER_LEFT; -fx-cursor: hand;" text="⚙️ Paramètres Admin" />

                <Region VBox.vgrow="ALWAYS" />

                <Button onAction="#deconnexion" prefWidth="200.0"
                        style="-fx-background-color: #e74c3c; -fx-background-radius: 5; -fx-cursor: hand;" text="Déconnexion" textFill="WHITE">
                    <font>
                        <Font name="System Bold" size="13.0" />
                    </font>
                </Button>
            </children>
        </VBox>
    </left>

    <center>
        <StackPane fx:id="contentArea" style="-fx-background-color: #f5f6fa; -fx-padding: 15;">
            <children>
                <VBox alignment="CENTER" spacing="10.0" style="-fx-background-color: white; -fx-background-radius: 10; -fx-border-color: #dcdde1; -fx-border-radius: 10;">
                    <effect>
                        <DropShadow color="#0000001a" radius="10" height="20" width="20" />
                    </effect>
                    <children>
                        <Label text="Bienvenue dans votre espace" textFill="#2f3640">
                            <font>
                                <Font name="System Bold" size="26.0" />
                            </font>
                        </Label>
                        <Label text="Système de Gestion Médicale" textFill="#7f8c8d">
                            <font>
                                <Font size="16.0" />
                            </font>
                        </Label>
                    </children>
                </VBox>
            </children>
        </StackPane>
    </center>
</BorderPane>