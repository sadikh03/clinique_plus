            <TableColumn fx:id="colUsername" prefWidth="100.0" text="MUsername" />
            <TableColumn fx:id="colLogin" prefWidth="186.4000244140625" text="Login" />
            <TableColumn fx:id="colRole" prefWidth="120.199951171875" text="Role" />
            <TableColumn fx:id="colPassword" prefWidth="259.800048828125" text="Password" />
        </columns>
