<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import javafx.collections.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="650.0" prefWidth="769.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="sn.sadikh.examen_javafx.controller.facture.FactureController">

    <Pane prefHeight="650.0" prefWidth="280.0" style="-fx-background-color: #2c3e50;">
        <Label layoutX="20.0" layoutY="20.0" text="Gestion Factures" textFill="WHITE">
            <font>
                <Font name="System Bold" size="18.0" />
            </font>
        </Label>

        <Label layoutX="20.0" layoutY="65.0" text="Montant total" textFill="WHITE" />
        <TextField fx:id="txtMontant" layoutX="20.0" layoutY="85.0" prefWidth="240.0" />

        <Label layoutX="20.0" layoutY="137.0" text="Date" textFill="WHITE" />
        <DatePicker fx:id="dtDate" layoutX="19.0" layoutY="167.0" prefWidth="240.0" />

        <Label layoutX="19.0" layoutY="225.0" text="Mode De Paiement" textFill="WHITE" />
        <ComboBox fx:id="cbModePaiement" layoutX="19.0" layoutY="260.0" prefWidth="240.0">
            <items>
                <FXCollections fx:factory="observableArrayList">
                    <String fx:value="Especes" />
                    <String fx:value="Carte Bancaire" />
                    <String fx:value="Chèque" />
                    <String fx:value="Wave / Mobile Money" />
                </FXCollections>
            </items>
        </ComboBox>

        <Label layoutX="20.0" layoutY="308.0" text="Consultation" textFill="WHITE" />
        <ComboBox fx:id="cbConsultation" layoutX="20.0" layoutY="340.0" prefWidth="240.0" />

        <Label layoutX="20.0" layoutY="386.0" text="Statut" textFill="WHITE" />
        <ComboBox fx:id="cbStatut" layoutX="19.0" layoutY="426.0" prefWidth="240.0" />

        <HBox layoutX="19.0" layoutY="600.0" spacing="10.0">
            <Button onAction="#modifier" prefWidth="115.0" style="-fx-background-color: #2980b9;" text="Modifier" textFill="WHITE" />
            <Button onAction="#annuler" prefWidth="115.0" style="-fx-background-color: #7f8c8d;" text="Annuler" textFill="WHITE" />
        </HBox>
        <HBox layoutX="19.0" layoutY="559.0" spacing="10.0" />
         <Button layoutX="21.0" layoutY="533.0" onAction="#enregistrer" prefHeight="26.0" prefWidth="236.0" style="-fx-background-color: #27ae60;" text="Enregistrer" textFill="WHITE" />
    </Pane>

    <TableView fx:id="table" layoutX="280.0" prefHeight="650.0" prefWidth="720.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="280.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
        <columns>
            <TableColumn fx:id="colId" prefWidth="40.0" text="ID" />
            <TableColumn fx:id="colModePaiement" prefWidth="100.0" text="Mode de paiement" />
            <TableColumn fx:id="colDate" prefWidth="110.0" text="Date" />
            <TableColumn fx:id="colMontant" prefWidth="100.0" text="Montant Total" />
            <TableColumn fx:id="colConsultation" prefWidth="130.0" text="Consultation" />
            <TableColumn fx:id="colStatut" prefWidth="130.0" text="Statut" />
        </columns>
    </TableView>

</AnchorPane>
